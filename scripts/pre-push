#!/usr/bin/env bash
# pre-push — push 前本地跑测试 + lint，不通过则拦截
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
test -n "$ROOT" || { echo "❌ 不在 git 仓库内"; exit 1; }
cd "$ROOT"

echo "🔍 pre-push: pytest..."
python3 -m pytest tests/ -q

echo "🔍 pre-push: ruff..."
ruff check skill/halucatch/ tests/

echo "✅ pre-push 通过"
